{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Transcriber-kun",
  "version": "1.0.0",
  "identifier": "com.transcriberkun.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Transcriber-kun",
        "width": 1200,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; media-src 'self' asset: blob: https: http://asset.localhost https://asset.localhost; img-src 'self' data: asset: http://asset.localhost https://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$TEMP/**",
          "$APPDATA/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/app-icon-32x32.png",
      "icons/app-icon-128x128.png",
      "icons/app-icon-128x128@2x.png",
      "icons/app-icon.icns",
      "icons/app-icon.ico"
    ],
    "resources": {
      "../python": "python",
      "../requirements.txt": "requirements.txt"
    },
    "macOS": {
      "minimumSystemVersion": "13.0",
      "signingIdentity": "-"
    }
  }
}
